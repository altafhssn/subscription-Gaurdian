# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback

# Database (PostgreSQL) — use Railway, Supabase, or Neon for free tier
DATABASE_URL=postgresql://user:password@localhost:5432/guardian

# App
PORT=3000
APP_URL=https://yourdomain.com

# Encryption key for Gmail tokens (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_32_byte_hex_key_here
