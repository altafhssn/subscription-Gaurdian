{
  "functions": {
    "api/waitlist.js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 10
    }
  },
  "overrides": {
    "*.html": {
      "contentType": "text/html"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
