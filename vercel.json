{
  "functions": {
    "api/waitlist.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node@3" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static", "continue": true }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
